# Database - For Vercel deployment, use a cloud database URL
# Option 1: SQLite (local dev only - won't work on Vercel)
DATABASE_URL=file:./dev.db

# Option 2: PostgreSQL (recommended for Vercel)
# DATABASE_URL=postgresql://user:password@host:5432/dbname?schema=public

# Option 3: MySQL (alternative for Vercel)
# DATABASE_URL=mysql://user:password@host:3306/dbname

# Admin password for the admin dashboard
ADMIN_PASSWORD=admin123
